# Optional overrides for telegram-gem-bridge.cjs
# Copy this file to bridge.env if you want to customize the bridge.

# BRIDGE_GEMINI_MODEL_QUALITY=gemini-3.1-pro-preview
# BRIDGE_GEMINI_MODEL_FAST=gemini-2.5-flash
# BRIDGE_GEMINI_TIMEOUT_MS=300000
# BRIDGE_SHARED_MEMORY_REFRESH_MS=300000
# BRIDGE_MEMORY_INGEST_IDLE_MS=120000
# MEMORY_ENABLE_SCORE_GATING=true
# MEMORY_MIN_CONFIDENCE=0.75
# MEMORY_MIN_IMPORTANCE=0.65
# MEMORY_VECTOR_ENABLED=true
# MEMORY_VECTOR_MODEL=bge-m3
# MEMORY_VECTOR_OLLAMA_URL=http://127.0.0.1:11434
# MEMORY_VECTOR_QUERY_TIMEOUT_MS=1200
# MEMORY_VECTOR_INDEX_TIMEOUT_MS=120000
# TELEGRAM_ALLOWED_CHAT_IDS=replace-with-your-chat-id
# TELEGRAM_GEM_BRIDGE_MUTEX_HOST=127.0.0.1
# TELEGRAM_GEM_BRIDGE_MUTEX_PORT=4145
# SHARED_MEMORY_URL=https://your-vercel-app.example/api/shared-memory
# SHARED_MEMORY_SYNC_TOKEN=replace-this-with-your-secret
# GEM_STATUS_URL=https://your-vercel-app.example/api/gem-status
# GEM_CONTROL_URL=https://your-vercel-app.example/api/gem-control
# GEM_STATUS_AGENT_INTERVAL_MS=60000
# GEM_PUBLIC_URL=https://your-public-openai-bridge.example
#
# Keep runtime/LMC memory out of bridge-workspace/GEMINI.md by default.
# BRIDGE_DYNAMIC_GEMINI_CONTEXT_ENABLED=false
# BRIDGE_HISTORY_SEED_RECENT_TURNS=35
# BRIDGE_HISTORY_SEED_MAX_TURNS=40
# BRIDGE_HISTORY_SEED_BATCH_CHARS=16000
#
# Telegram polling recovery guards.
# BRIDGE_TELEGRAM_POLLING_RESTART_STOP_TIMEOUT_MS=30000
# BRIDGE_TELEGRAM_POLLING_RESTART_START_TIMEOUT_MS=300000
# BRIDGE_TELEGRAM_POLLING_RESTART_MAX_ATTEMPTS=1
# BRIDGE_TELEGRAM_STOP_ON_PERSISTENT_409=true
#
# Antigravity sidecar request guard.
# BRIDGE_ANTIGRAVITY_SIDECAR_REQUEST_TIMEOUT_MS=300000
#
# Antigravity direct OAuth refresh clients. Use either JSON or the pair variables.
# ANTIGRAVITY_OAUTH_CLIENTS_JSON=[{"id":"replace-with-client-id","secret":"replace-with-client-secret"}]
# ANTIGRAVITY_OAUTH_CLIENT_ID=replace-with-client-id
# ANTIGRAVITY_OAUTH_CLIENT_SECRET=replace-with-client-secret
# ANTIGRAVITY_OAUTH_CLIENT_ID_2=replace-with-second-client-id
# ANTIGRAVITY_OAUTH_CLIENT_SECRET_2=replace-with-second-client-secret
#
# Optional overrides for codex-status-agent.cjs
# CODEX_STATUS_URL=https://your-vercel-app.example/api/codex-status
# CODEX_CONTROL_URL=https://your-vercel-app.example/api/codex-control
# CODEX_STATUS_AGENT_INTERVAL_MS=60000
# CODEX_QI_PROCESS_PATTERN=your-codex-qi-process-name-or-script
# CODEX_QI_START_COMMAND=C:\path\to\start-qi.cmd
# CODEX_QI_RESTART_COMMAND=C:\path\to\restart-qi.cmd
#
# Optional overrides for gemini-cli-openai-bridge.cjs
# OPENAI_BRIDGE_HOST=0.0.0.0
# OPENAI_BRIDGE_PORT=4141
# OPENAI_BRIDGE_API_KEY=replace-this-with-a-local-secret
# OPENAI_BRIDGE_DEFAULT_MODEL=gemini-3.1-pro-preview
# OPENAI_BRIDGE_TIMEOUT_MS=300000
# OPENAI_BRIDGE_STREAM_UPDATE_MS=700
#
# Optional overrides for ST-lite RP Runtime in gem-chat-record-manager.cjs
# If these are missing, /api/rp/generate returns a safe placeholder reply.
# RP_MODEL_BASE_URL=https://api.openai.com/v1
# RP_MODEL_API_KEY=replace-this-with-your-model-key
# RP_MODEL_NAME=gpt-4.1-mini
# RP_MODEL_WIRE_API=chat_completions
# RP_MODEL_WIRE_API=responses
#
# Optional separate model for RP memory table updates.
# If these are missing, the memory updater reuses RP_MODEL_*.
# RP_MEMORY_MODEL_BASE_URL=http://127.0.0.1:4141/v1
# RP_MEMORY_MODEL_API_KEY=local-rp-bridge
# RP_MEMORY_MODEL_NAME=gemini-3.1-flash-lite-preview
# RP_MEMORY_MODEL_WIRE_API=chat_completions
# RP_MEMORY_AUTO_ENABLED=1
# RP_MEMORY_AUTO_EVERY_TURNS=3
# RP_MEMORY_TEMPERATURE=0.2
# RP_MEMORY_MAX_TOKENS=1600
# HTTP_PROXY=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808
# NO_PROXY=localhost,127.0.0.1
